# OpenRouter — single key for all models (Claude, GPT-4o, Llama, etc.)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model overrides (optional — these are the defaults)
# PRIMARY_MODEL=anthropic/claude-sonnet-4        # analyst (deep reasoning)
# SECONDARY_MODEL=openai/gpt-4o-mini             # critic + synthesizer (cheap)
# CRITIC_MODEL=openai/gpt-4o-mini

# RAG
# VECTOR_STORE_PATH=./data/vectorstore
# CHUNK_SIZE=512
# RETRIEVAL_TOP_K=5

# AWS (for deployment)
# AWS_REGION=us-east-1
# S3_BUCKET=fable-rag-docs
